---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog">
  <h1 class="text-3xl font-bold mb-8 max-sm:text-2xl">Blog</h1>

  {posts.length === 0 ? (
    <p class="mb-4">No posts yet. Check back soon!</p>
  ) : (
    <ul class="list-none p-0">
      {posts.map((post) => (
        <li class="py-4 border-b border-[var(--color-border)] last:border-b-0">
          <a href={`/blog/${post.id}/`} class="text-lg font-medium text-[var(--color-accent)] hover:underline">{post.data.title}</a>
          <time class="block text-sm text-[var(--color-text-muted)]" datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString("en-GB", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </time>
          <p class="mt-2 text-sm text-[var(--color-text-muted)]">{post.data.description}</p>
        </li>
      ))}
    </ul>
  )}
</Layout>
