---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog">
  <h1 class="fs-2 fw-bold mb-4">Blog</h1>

  {posts.length === 0 ? (
    <p class="mb-3">No posts yet. Check back soon!</p>
  ) : (
    <ul class="list-unstyled p-0">
      {posts.map((post, i) => (
        <li class:list={["py-3 border-bottom", { "border-bottom-0": i === posts.length - 1 }]} style={`border-color: var(--color-border) !important;`}>
          <a href={`/blog/${post.id}/`} class="fs-5 fw-medium">{post.data.title}</a>
          <time class="d-block small" style={`color: var(--color-text-muted);`} datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString("en-GB", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </time>
          <p class="mt-2 small mb-0" style={`color: var(--color-text-muted);`}>{post.data.description}</p>
        </li>
      ))}
    </ul>
  )}
</Layout>
