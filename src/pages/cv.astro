---
import Layout from "../layouts/Layout.astro";
---

<Layout title="CV">
  <h1 class="fs-2 fw-bold mb-4">CV</h1>

  <!-- Replace the placeholder content below with your own -->

  <section class="mb-5">
    <h2 class="fs-4 fw-semibold border-bottom pb-2 mb-4" style={`border-color: var(--color-border) !important;`}>Experience</h2>

    <div class="mb-4">
      <h3 class="fs-5 fw-semibold mb-1">Job Title — Company Name</h3>
      <p class="small mb-2" style={`color: var(--color-text-muted);`}>2020 – Present</p>
      <p class="mb-3">Describe your role, responsibilities, and key achievements.</p>
    </div>

    <div class="mb-4">
      <h3 class="fs-5 fw-semibold mb-1">Previous Role — Previous Company</h3>
      <p class="small mb-2" style={`color: var(--color-text-muted);`}>2016 – 2020</p>
      <p class="mb-3">Describe your role, responsibilities, and key achievements.</p>
    </div>
  </section>

  <section class="mb-5">
    <h2 class="fs-4 fw-semibold border-bottom pb-2 mb-4" style={`border-color: var(--color-border) !important;`}>Education</h2>

    <div class="mb-4">
      <h3 class="fs-5 fw-semibold mb-1">Degree — University Name</h3>
      <p class="small mb-2" style={`color: var(--color-text-muted);`}>2012 – 2016</p>
      <p class="mb-3">Details about your studies, thesis, or notable achievements.</p>
    </div>
  </section>

  <section class="mb-5">
    <h2 class="fs-4 fw-semibold border-bottom pb-2 mb-4" style={`border-color: var(--color-border) !important;`}>Skills</h2>
    <ul class="ps-4 mb-3">
      <li>Skill or technology</li>
      <li>Skill or technology</li>
      <li>Skill or technology</li>
    </ul>
  </section>
</Layout>
