---
import Layout from "../layouts/Layout.astro";
---

<Layout title="CV">
  <h1 class="text-3xl font-bold mb-8 max-sm:text-2xl">CV</h1>

  <!-- Replace the placeholder content below with your own -->

  <section class="mb-16">
    <h2 class="text-2xl font-semibold border-b border-[var(--color-border)] pb-2 mb-8">Experience</h2>

    <div class="mb-8">
      <h3 class="text-xl font-semibold mb-1">Job Title — Company Name</h3>
      <p class="text-sm text-[var(--color-text-muted)] mb-2">2020 – Present</p>
      <p class="mb-4">Describe your role, responsibilities, and key achievements.</p>
    </div>

    <div class="mb-8">
      <h3 class="text-xl font-semibold mb-1">Previous Role — Previous Company</h3>
      <p class="text-sm text-[var(--color-text-muted)] mb-2">2016 – 2020</p>
      <p class="mb-4">Describe your role, responsibilities, and key achievements.</p>
    </div>
  </section>

  <section class="mb-16">
    <h2 class="text-2xl font-semibold border-b border-[var(--color-border)] pb-2 mb-8">Education</h2>

    <div class="mb-8">
      <h3 class="text-xl font-semibold mb-1">Degree — University Name</h3>
      <p class="text-sm text-[var(--color-text-muted)] mb-2">2012 – 2016</p>
      <p class="mb-4">Details about your studies, thesis, or notable achievements.</p>
    </div>
  </section>

  <section class="mb-16">
    <h2 class="text-2xl font-semibold border-b border-[var(--color-border)] pb-2 mb-8">Skills</h2>
    <ul class="pl-6 mb-4">
      <li>Skill or technology</li>
      <li>Skill or technology</li>
      <li>Skill or technology</li>
    </ul>
  </section>
</Layout>
