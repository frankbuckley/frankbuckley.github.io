---
import Layout from "./Layout.astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
}

const { title, description, pubDate, tags } = Astro.props;
---

<Layout title={title}>
  <article>
    <header>
      <h1 class="fs-2 fw-bold mb-3">{title}</h1>
      <div class="d-flex align-items-center gap-3 mb-4 small" style={`color: var(--color-text-muted);`}>
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString("en-GB", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
        {tags.length > 0 && tags.map((tag) => (
          <span class="badge rounded-pill" style={`background-color: var(--color-border); color: var(--color-text);`}>{tag}</span>
        ))}
      </div>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</Layout>
