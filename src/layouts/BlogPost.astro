---
import Layout from "./Layout.astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
}

const { title, description, pubDate, tags } = Astro.props;
---

<Layout title={title}>
  <article>
    <header>
      <h1 class="text-3xl font-bold mb-4 max-sm:text-2xl">{title}</h1>
      <div class="flex items-center gap-4 mb-8 text-sm text-[var(--color-text-muted)]">
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString("en-GB", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
        {tags.length > 0 && tags.map((tag) => (
          <span class="bg-[var(--color-border)] px-2 py-0.5 rounded text-xs">{tag}</span>
        ))}
      </div>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</Layout>
