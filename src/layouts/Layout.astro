---
import '../styles/default.css';
import Nav from '../components/Nav.astro';

interface Props {
	title?: string;
}

const { title = 'Frank Buckley' } = Astro.props;
const fullTitle = title === 'Frank Buckley' ? title : `${title} — Frank Buckley`;

const socialLinks = [
	{ href: "https://bsky.app/profile/frankbuckley.com", label: "Bluesky", icon: "bi-bluesky" },
	{ href: "https://github.com/frankbuckley", label: "Github", icon: "bi-github" },
	{ href: "https://orcid.org/0000-0002-9708-2705", label: "ORCID", icon: "bi-link-45deg" },
	{ href: "https://www.researchgate.net/profile/Frank-Buckley", label: "ResearchGate", icon: "bi-link-45deg" },
	{ href: "https://www.linkedin.com/in/frankbuckley", label: "LinkedIn", icon: "bi-linkedin" },
];
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="alternate" type="application/rss+xml" title="Frank Buckley" href="/rss.xml" />
		<title>{fullTitle}</title>
	</head>
	<body class="d-flex flex-column min-vh-100" style={`color: var(--color-text); line-height: 1.75;`}>
		<header class="border-bottom px-4 py-3" style={`border-color: var(--color-border) !important;`}>
			<Nav />
		</header>
		<main class="flex-grow-1 w-100 mx-auto px-4 py-5 py-sm-5" style="max-width: 42rem;">
			<slot />
		</main>
		<footer class="border-top px-4 py-3 text-center small" style={`border-color: var(--color-border) !important; color: var(--color-text-muted);`}>
			<nav class="d-flex justify-content-center gap-3 mb-2">
				{socialLinks.map(({ href, label, icon }) => (
					<a href={href} class="link-secondary text-decoration-none d-inline-flex align-items-center gap-1" target="_blank" rel="noopener noreferrer" aria-label={label}>
						<i class={`bi ${icon}`} aria-hidden="true"></i>
						<span>{label}</span>
					</a>
				))}
			</nav>
			<p>&copy; {new Date().getFullYear()} Frank Buckley</p>
		</footer>
	</body>
</html>

